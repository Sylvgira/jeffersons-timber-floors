---
interface FAQ {
  data: {
    question: string;
    answer: string;
  };
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<div class="faq-list" data-faq-accordion>
  {faqs.map((faq) => (
    <details>
      <summary>
        <span>{faq.data.question}</span>
        <svg class="faq-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </summary>
      <div class="faq-answer">
        <div class="faq-answer-inner">
          <p>{faq.data.answer}</p>
          <div class="faq-answer__spacer"></div>
        </div>
      </div>
    </details>
  ))}
</div>

<script>
  const containers = document.querySelectorAll('[data-faq-accordion]');
  containers.forEach((container) => {
    container.classList.add('faq-list--js');

    const detailsElements = container.querySelectorAll('details');
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    detailsElements.forEach((details) => {
      const summary = details.querySelector('summary');

      summary.addEventListener('click', (e) => {
        e.preventDefault();

        if (details.dataset.state === 'closing') return;

        if (!details.open) {
          detailsElements.forEach((other) => {
            if (other !== details && other.open) {
              closeDetails(other);
            }
          });
          openDetails(details);
        } else {
          closeDetails(details);
        }
      });
    });

    function openDetails(details) {
      details.open = true;
      if (isReducedMotion) {
        details.dataset.state = 'open';
        return;
      }
      
      const content = details.querySelector('.faq-answer');
      content.offsetHeight; // Force reflow
      details.dataset.state = 'open';
    }

    function closeDetails(details) {
      if (isReducedMotion) {
        details.open = false;
        details.dataset.state = '';
        return;
      }

      details.dataset.state = 'closing';
      const content = details.querySelector('.faq-answer');

      const onTransitionEnd = (e) => {
        if (e.propertyName === 'grid-template-rows') {
          content.removeEventListener('transitionend', onTransitionEnd);
          if (details.dataset.state === 'closing') {
            details.open = false;
            details.dataset.state = '';
          }
        }
      };

      content.addEventListener('transitionend', onTransitionEnd);
    }
  });
</script>

<style>
  .faq-list {
    border-top: 1px solid var(--color-rule);
  }

  details {
    border-bottom: 1px solid var(--color-rule);
    padding-block: 0;
  }

  summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-5);
    cursor: pointer;
    color: var(--color-heading);
    font-weight: 800;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--color-gold);
    transform: rotate(90deg);
    transition: transform 0.25s ease;
  }

  details[data-state="open"] .faq-chevron,
  .faq-list:not(.faq-list--js) details[open] .faq-chevron {
    transform: rotate(-90deg);
  }

  .faq-answer {
    display: grid;
    grid-template-rows: 0fr;
    overflow: hidden;
    transition: grid-template-rows 0.3s ease-in-out;
  }

  .faq-answer-inner {
    min-height: 0;
    opacity: 0;
    transition: opacity 0.2s ease-in-out;
  }

  /* JS Active Styles */
  .faq-list--js details[data-state="open"] .faq-answer {
    grid-template-rows: 1fr;
  }

  .faq-list--js details[data-state="open"] .faq-answer-inner {
    opacity: 1;
    transition: opacity 0.25s ease-in-out 0.05s;
  }

  /* JS Inactive Fallbacks */
  .faq-list:not(.faq-list--js) details[open] .faq-answer {
    grid-template-rows: 1fr;
  }

  .faq-list:not(.faq-list--js) details[open] .faq-answer-inner {
    opacity: 1;
  }

  .faq-answer p {
    margin: 0;
  }

  .faq-answer__spacer {
    height: var(--space-5);
  }

  details p {
    max-width: 48rem;
  }
</style>
