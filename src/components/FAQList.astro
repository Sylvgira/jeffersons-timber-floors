---
interface FAQ {
  data: {
    question: string;
    answer: string;
  };
}

interface Props {
  faqs: FAQ[];
}

const { faqs } = Astro.props;
---

<div class="faq-list">
  {faqs.map((faq) => (
    <details>
      <summary>{faq.data.question}</summary>
      <p>{faq.data.answer}</p>
    </details>
  ))}
</div>

<style>
  .faq-list {
    border-top: 1px solid var(--color-rule);
  }

  details {
    border-bottom: 1px solid var(--color-rule);
    padding-block: var(--space-5);
  }

  summary {
    cursor: pointer;
    color: var(--color-heading);
    font-weight: 800;
  }

  details p {
    max-width: 48rem;
    margin: var(--space-4) 0 0;
  }
</style>
