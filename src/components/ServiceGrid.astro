---
interface Service {
  id?: string;
  data: {
    title: string;
    summary: string;
  };
}

interface Props {
  services: Service[];
  variant?: 'grid' | 'list' | 'featured-first';
}

const { services, variant = 'grid' } = Astro.props;
const pathFor = (service: Service) => `/services/${service.id}/`;
---

<div class:list={['service-grid', `service-grid--${variant}`]}>
  {services.map((service) => (
    <a class="service-card" href={pathFor(service)}>
      <h3>{service.data.title}</h3>
      <p>{service.data.summary}</p>
      <span>Read more</span>
    </a>
  ))}
</div>

<style>
  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .service-grid--list {
    grid-template-columns: 1fr;
  }

  .service-grid--list .service-card {
    display: grid;
    grid-template-columns: minmax(10rem, 0.45fr) minmax(0, 1fr) auto;
    gap: var(--space-5);
    align-items: start;
    min-height: auto;
  }

  .service-grid--featured-first .service-card:first-child {
    grid-column: span 2;
    min-height: 20rem;
    background: var(--color-section);
  }

  .service-card {
    display: flex;
    min-height: 17rem;
    flex-direction: column;
    justify-content: space-between;
    padding: var(--space-5);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius-md);
    color: inherit;
    text-decoration: none;
  }

  .service-card:hover {
    border-color: var(--color-text);
  }

  .service-card h3 {
    margin-bottom: var(--space-4);
  }

  .service-card p {
    flex: 1;
  }

  .service-card span {
    color: var(--color-link);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  @media (max-width: 860px) {
    .service-grid {
      grid-template-columns: 1fr;
    }

    .service-grid--list .service-card {
      display: flex;
    }

    .service-grid--featured-first .service-card:first-child {
      grid-column: auto;
    }
  }
</style>
