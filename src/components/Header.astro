---
interface NavItem {
  label: string;
  href: string;
}

interface Props {
  site: {
    name: string;
    ctaLabel?: string;
    ctaUrl?: string;
  };
  pathname: string;
}

const { site, pathname } = Astro.props;
const nav: NavItem[] = [
  { label: 'About', href: '/about/' },
  { label: 'Services', href: '/services/' },
  { label: 'News', href: '/blog/' },
  { label: 'Contact', href: '/contact/' }
];

const isCurrent = (href: string) => pathname === href || pathname.startsWith(href);
---

<header class="site-header">
  <div class="site-header__inner container">
    <a class="site-header__brand" href="/" aria-label={`${site.name} home`}>
      <img src="/uploads/jeffersons-logo.svg" alt="Jefferson's Timber Floors" class="site-header__logo" />
    </a>
    <nav class="site-header__nav" aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} aria-current={isCurrent(item.href) ? 'page' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>
    <a class="site-header__cta button button--secondary-light" href={site.ctaUrl ?? '/contact/'}>
      {site.ctaLabel ?? 'Enquire'}
    </a>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-dark);
    color: var(--color-white);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-5);
    align-items: center;
    min-height: 4.75rem;
  }

  .site-header__brand {
    color: var(--color-white);
    text-decoration: none;
    line-height: 0;
  }

  .site-header__logo {
    height: 3.5rem;
    width: auto;
    display: block;
  }

  .site-header__nav {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }

  .site-header__nav a {
    color: var(--color-dark-text-muted);
    font-size: var(--text-sm);
    font-weight: 650;
    text-decoration: none;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    transition: color 0.2s;
  }

  .site-header__nav a:hover,
  .site-header__nav a[aria-current='page'] {
    color: var(--color-white);
  }

  .site-header__cta {
    min-height: 2.5rem;
    padding-inline: var(--space-4);
    border-color: var(--color-dark-border-medium);
    color: var(--color-white);
  }

  @media (max-width: 760px) {
    .site-header__inner {
      grid-template-columns: 1fr auto;
      gap: var(--space-3);
      padding-block: var(--space-4);
    }

    .site-header__nav {
      grid-column: 1 / -1;
      order: 3;
      justify-content: space-between;
      overflow-x: auto;
      padding-top: var(--space-2);
    }

    .site-header__cta {
      justify-self: end;
    }
  }
</style>
