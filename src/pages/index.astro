---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Section from '@components/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import Testimonials from '@components/Testimonials.astro';
import FAQList from '@components/FAQList.astro';
import GalleryBlock from '@components/GalleryBlock.astro';
import TrustBar from '@components/TrustBar.astro';
import { byOrder } from '../lib/content';

const site = await getEntry('settings', 'site');
const home = await getEntry('pages', 'home');
const services = byOrder(await getCollection('services'));
const testimonials = byOrder(await getCollection('testimonials'));
const faqs = byOrder(await getCollection('faqs'));

const hero = home?.data.hero;

const serviceIcons = [
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="16" height="4" rx="0.5"/><rect x="2" y="9" width="20" height="4" rx="0.5"/><rect x="2" y="15" width="14" height="4" rx="0.5"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="8"/><line x1="12" y1="16" x2="12" y2="22"/><line x1="2" y1="12" x2="8" y2="12"/><line x1="16" y1="12" x2="22" y2="12"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>`,
  `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
];

const servicesWithIcons = services.map((s, i) => ({
  ...s,
  data: {
    ...s.data,
    icon: serviceIcons[i % serviceIcons.length]
  }
}));
---

<BaseLayout>
  <Hero
    variant={hero?.variant ?? 'image-full'}
    eyebrow={hero?.eyebrow}
    title={hero?.title ?? 'Melbourne\'s Trusted Timber Floor Specialists'}
    intro={hero?.intro ?? 'Premium engineered timber flooring, professional installation, and subfloor preparation for homes and businesses across Melbourne.'}
    primaryLabel={hero?.primaryLabel ?? 'Get a free quote'}
    primaryUrl={hero?.primaryUrl ?? '/contact/'}
    secondaryLabel={hero?.secondaryLabel}
    secondaryUrl={hero?.secondaryUrl}
    imageUrl="/uploads/hero-bg.jpg"
  />

  <Section
    eyebrow="What we do"
    title="Our Services"
  >
    <ServiceGrid services={servicesWithIcons} variant={home?.data.servicesVariant ?? 'icon-grid'} />
  </Section>

  <Section
    eyebrow="Our work"
    title="Quality Workmanship"
    intro="Every floor we finish is a reflection of our commitment to detail. Browse a selection of recent projects across Melbourne."
  >
    <GalleryBlock
      variant={home?.data.galleryVariant ?? 'portfolio'}
      items={[
        { title: 'Formal Living', description: 'Rich hardwood flooring in a formal living room setting', imageUrl: '/uploads/showcase-01.jpg' },
        { title: 'Open-Plan Living', description: 'Premium timber flooring across open-plan dining and living areas', imageUrl: '/uploads/showcase-02.jpg' },
        { title: 'Minimalist Interior', description: 'Pale oak floorboards in a bright, contemporary home', imageUrl: '/uploads/showcase-03.jpg' },
        { title: 'Modern Dining', description: 'Honey-toned timber flooring in an open-plan dining space', imageUrl: '/uploads/showcase-04.jpg' }
      ]}
    />
  </Section>

  <TrustBar
    title="Why choose Jefferson's?"
    items={[
      { label: '20+ Years Experience' },
      { label: 'Licensed & Insured' },
      { label: '5-Star Rated' }
    ]}
    ctaLabel="Get a free quote"
    ctaUrl="/contact/"
  />

  <Section
    eyebrow="Testimonials"
    title="What our clients say"
    intro="Real feedback from Melbourne homeowners and businesses who trust us with their timber floors."
  >
    <Testimonials testimonials={testimonials} variant={home?.data.testimonialsVariant} />
  </Section>

  <Section variant="surface" eyebrow="Questions" title="Frequently asked questions">
    <FAQList faqs={faqs} />
  </Section>
</BaseLayout>
