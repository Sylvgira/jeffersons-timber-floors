---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/PageIntro.astro';
import Section from '@components/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import CTABand from '@components/CTABand.astro';
import { byOrder } from '../../lib/content';

const services = byOrder(await getCollection('services'));
---

<BaseLayout title="Services" description="Engineered timber flooring, professional installation, and subfloor preparation — explore our full range of services across Melbourne.">
  <PageIntro
    eyebrow="Services"
    title="Everything your floors need"
    intro="From engineered timber supply to full installation and subfloor preparation, we handle the full range of timber flooring services."
  />

  <Section>
    <ServiceGrid services={services} />
  </Section>

  <CTABand
    title="Not sure what you need?"
    text="Get in touch and we'll visit your property to assess your floors and recommend the best approach."
  />
</BaseLayout>
