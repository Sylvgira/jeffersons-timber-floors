---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/PageIntro.astro';
import Section from '@components/Section.astro';
import ServiceGrid from '@components/ServiceGrid.astro';
import CTABand from '@components/CTABand.astro';
import { byOrder } from '../../lib/content';

const services = byOrder(await getCollection('services'));
const page = await getEntry('pages', 'services');
const { data } = page;
---

<BaseLayout title={data.seoTitle} description={data.seoDescription}>
  <PageIntro
    eyebrow={data.eyebrow}
    title={data.title}
    intro={data.intro}
  />

  <Section>
    <ServiceGrid services={services} />
  </Section>

  <CTABand
    title="Not sure what you need?"
    text="Get in touch and we'll visit your property to assess your floors and recommend the best approach."
  />
</BaseLayout>
